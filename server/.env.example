# Required: PostgreSQL connection string (e.g. from Neon, Supabase, Railway, or local)
DATABASE_URL=postgresql://user:password@host/dbname

# Required: secret used to sign JWTs — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# Optional: restrict CORS to your frontend URL in production
# ALLOWED_ORIGIN=https://yourdomain.com

# Optional: defaults to 3001
# PORT=3001

# Email (Resend) — required for email features (signup notifications, password reset)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# Email address to notify when a new user registers
# ADMIN_EMAIL=you@example.com

# Base URL of your frontend — used in password reset links
# APP_URL=http://localhost:5173

# From address shown on emails (must be a verified domain in Resend)
# EMAIL_FROM=GHCdb <noreply@yourdomain.com>
